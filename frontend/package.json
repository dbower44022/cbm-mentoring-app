{
  "name": "mentorapp-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser rendering layer for the CBM Mentoring App (DEC-079). Renders the Python view-model payloads served by the FastAPI backend; behavior lives server-side.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "gen:api": "openapi-typescript http://127.0.0.1:8000/openapi.json -o src/api/schema.d.ts",
    "test": "vitest run",
    "e2e": "playwright test",
    "check": "tsc --noEmit && eslint . --max-warnings 0 && prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.20.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.6.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^5.4.14",
    "vitest": "^4.1.9"
  }
}
